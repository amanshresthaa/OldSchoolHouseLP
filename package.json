{
  "name": "OldSchoolHouseLP",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "precommit:lint-staged": "lint-staged",
    "precommit:typecheck": "pnpm typecheck",
    "precommit:check": "pnpm precommit:lint-staged && pnpm precommit:typecheck",
    "readiness:dead-code": "knip --config knip.json --reporter compact --no-progress",
    "readiness:duplicate-code": "jscpd --config jscpd.json",
    "readiness:tech-debt": "node ./scripts/readiness/tech-debt-scan.mjs",
    "readiness:scan": "pnpm readiness:dead-code && pnpm readiness:duplicate-code && pnpm readiness:tech-debt"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --max-warnings=0 --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": "prettier --write"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "knip": "^6.0.4",
    "lint-staged": "^16.4.0",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "ts-prune": "^0.10.3",
    "typescript": "^5.9.3"
  }
}
