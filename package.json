{
  "name": "OldSchoolHouseLP",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:smoke": "PORT=3001 next dev --hostname 127.0.0.1 --turbopack",
    "build": "next build",
    "build:ci": "CI=1 node ./scripts/readiness/build-performance-track.mjs",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "pnpm test:unit && pnpm test:browser",
    "test:unit:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:unit:perf": "node ./scripts/readiness/test-performance-track.mjs",
    "prepare": "husky",
    "precommit:lint-staged": "lint-staged",
    "precommit:typecheck": "pnpm typecheck",
    "precommit:check": "pnpm precommit:lint-staged && pnpm precommit:typecheck",
    "test:unit": "pnpm test:unit:coverage",
    "test:browser": "playwright test",
    "readiness:dead-code": "knip --config knip.json --reporter compact --no-progress",
    "readiness:duplicate-code": "jscpd --config jscpd.json",
    "readiness:large-files": "node ./scripts/readiness/large-file-scan.mjs",
    "readiness:tech-debt": "node ./scripts/readiness/tech-debt-scan.mjs",
    "readiness:scan": "pnpm readiness:dead-code && pnpm readiness:duplicate-code && pnpm readiness:large-files && pnpm readiness:tech-debt"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --max-warnings=0 --no-warn-ignored --fix",
      "prettier --write"
    ],
    "*": "pnpm readiness:large-files",
    "*.{json,md,css}": "prettier --write"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "husky": "^9.1.7",
    "jscpd": "^4.0.9",
    "jsdom": "^29.0.1",
    "knip": "^6.0.4",
    "lint-staged": "^16.4.0",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "ts-prune": "^0.10.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  }
}
